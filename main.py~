@bot.command(name="disponibles")
async def cmd_boletos_disponibles(ctx):
    """Ver números disponibles"""
    if not await verificar_canal(ctx):
        return
    
    rifa_activa = await bot.db.get_rifa_activa()
    if not rifa_activa:
        await ctx.send(embed=embeds.crear_embed_error("No hay rifa activa"))
        return
    
    disponibles = await bot.db.get_boletos_disponibles(rifa_activa['id'])
    
    if not disponibles:
        await ctx.send(embed=embeds.crear_embed_info("🎟️ Boletos disponibles", "**¡No quedan boletos disponibles!**\nEl sorteo será pronto."))
        return
    
    total = rifa_activa['total_boletos']
    matriz = []
    for i in range(1, total + 1, 10):
        fila = []
        for j in range(10):
            num = i + j
            if num <= total:
                if num in disponibles:
                    fila.append(f"`{num:03d}`")
                else:
                    fila.append(f"~~`{num:03d}`~~")
        matriz.append(" ".join(fila))
    
    embed = discord.Embed(
        title=f"🎟️ Boletos disponibles ({len(disponibles)}/{total})",
        description="\n".join(matriz[:5]),
        color=config.COLORS['info']
    )
    embed.set_footer(text="Usa !comprar [número] para participar")
    
    await ctx.send(embed=embed)

