@bot.command(name="aumentarnumeros")
async def cmd_aumentar_numeros(ctx, cantidad_nuevos: int):
    """[ADMIN] Aumenta la cantidad de boletos de la rifa activa"""
    if not await check_admin(ctx):
        await ctx.send("❌ No tienes permiso para usar este comando")
        return
    
    rifa_activa = await bot.db.get_rifa_activa()
    if not rifa_activa:
        await ctx.send(embed=embeds.crear_embed_error("No hay rifa activa"))
        return
    
    if cantidad_nuevos <= 0:
        await ctx.send(embed=embeds.crear_embed_error("La cantidad debe ser mayor a 0"))
        return
    
    async with aiosqlite.connect(bot.db.db_path) as db:
        # Obtener total actual
        cursor = await db.execute('SELECT total_boletos FROM rifas WHERE id = ?', (rifa_activa['id'],))
        total_actual = (await cursor.fetchone())[0]
        
        # Calcular nuevo total
        nuevo_total = total_actual + cantidad_nuevos
        
        # Actualizar la rifa
        await db.execute('''
            UPDATE rifas SET total_boletos = ? WHERE id = ?
        ''', (nuevo_total, rifa_activa['id']))
        
        await db.commit()
    
    # Obtener números disponibles actualizados
    disponibles = await bot.db.get_boletos_disponibles(rifa_activa['id'])
    vendidos = await bot.db.get_boletos_vendidos(rifa_activa['id'])
    
    embed = discord.Embed(
        title="📈 RIFA AMPLIADA",
        description=f"Se agregaron **{cantidad_nuevos}** boletos nuevos",
        color=config.COLORS['success']
    )
    embed.add_field(name="🎟️ Total anterior", value=f"{total_actual} boletos", inline=True)
    embed.add_field(name="🎟️ Nuevo total", value=f"{nuevo_total} boletos", inline=True)
    embed.add_field(name="📊 Vendidos", value=f"{vendidos} boletos", inline=True)
    embed.add_field(name="✅ Disponibles ahora", value=f"**{len(disponibles)}** números", inline=True)
    embed.add_field(name="💰 Nuevos números", value=f"Del #{total_actual + 1} al #{nuevo_total}", inline=False)
    
    await ctx.send(embed=embed)
    await enviar_log(ctx, "📈 AMPLIACIÓN DE RIFA", f"{ctx.author.name} agregó {cantidad_nuevos} boletos (total: {total_actual} → {nuevo_total})")

