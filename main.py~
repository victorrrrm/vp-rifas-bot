    with open(archivo, 'w', newline='') as f:
        writer = csv.writer(f)
        writer.writerow(['Número', 'Rifa', 'Comprador', 'Vendedor ID', 'Precio', 'Fecha'])
        for b in boletos:
            writer.writerow([b['numero'], b['rifa'], b['comprador_nick'], 
                           b['vendedor_id'], b['precio_pagado'], b['fecha_compra']])
    
    await ctx.send(embed=embeds.crear_embed_exito(f"✅ Datos exportados a:\n{archivo}"))
    await enviar_log(ctx, "📊 EXPORTAR", f"{ctx.author.name} exportó datos a CSV")

@bot.command(name="backup")
async def cmd_backup(ctx):
    """Crear backup de la base de datos"""
    if not await check_ceo(ctx):
        await ctx.send("❌ Solo el CEO puede usar este comando")
        return
    
    fecha = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup_path = f"backups/rifas_backup_{fecha}.db"
    
    shutil.copy2(bot.db.db_path, backup_path)
    
    embed = embeds.crear_embed_exito(f"✅ Backup creado: {backup_path}")
    await ctx.send(embed=embed)
    await enviar_log(ctx, "💾 BACKUP", f"{ctx.author.name} creó backup: {backup_path}")

